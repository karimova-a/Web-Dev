## Step 1: Modify `product-list.ts` (TypeScript)

Open `src/app/components/product-list/product-list.ts` and replace its content with the code below. It adds signals for favorites, computed values, and methods.

```typescript
import { Component, signal, computed } from '@angular/core';
import { CommonModule } from '@angular/common';
import { ProductCardComponent } from '../product-card/product-card';
import { Product } from '../../models/product.model';

@Component({
  selector: 'app-product-list',
  standalone: true,
  imports: [CommonModule, ProductCardComponent],
  templateUrl: './product-list.html',
  styleUrls: ['./product-list.css']
})
export class ProductListComponent {
  // Existing product array (make sure you have at least 10 products)
  products: Product[] = [
    // ... your products here (keep your existing array)
  ];

  // Signals for favorites
  favoriteIds = signal<number[]>([]);          // stores IDs of favorite products
  showFavoritesOnly = signal<boolean>(false);  // toggle view

  // Computed signals
  favoriteCount = computed(() => this.favoriteIds().length);

  displayedProducts = computed(() => {
    if (this.showFavoritesOnly()) {
      return this.products.filter(p => this.favoriteIds().includes(p.id));
    }
    return this.products;
  });

  // Methods
  toggleFavorite(productId: number) {
    this.favoriteIds.update(currentIds => {
      if (currentIds.includes(productId)) {
        return currentIds.filter(id => id !== productId);
      } else {
        return [...currentIds, productId];
      }
    });
  }

  isFavorite(productId: number): boolean {
    return this.favoriteIds().includes(productId);
  }
}
```

**Explanation**:
- `favoriteIds` is a signal holding an array of product IDs that are favorited.
- `showFavoritesOnly` toggles the view between all products and only favorites.
- `favoriteCount` automatically updates when `favoriteIds` changes.
- `displayedProducts` returns the filtered list based on the toggle.
- `toggleFavorite` adds or removes an ID using the `update` method.
- `isFavorite` checks if a product is in the favorites list.

